# ─── LLM ──────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=

# ─── Observability ────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=my-health-assistant

# ─── Database (Supabase) ──────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_DB_URL=

# ─── Naver Maps API ───────────────────────────────────────────────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ─── 심평원 HIRA API ──────────────────────────────────────────────────────────
HIRA_API_KEY=

# ─── 인증 (Clerk) ─────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=
# Clerk JWKS URL (커스텀 도메인 사용 시 변경)
CLERK_JWKS_URL=https://api.clerk.dev/v1/jwks

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── 개발 환경 설정 ────────────────────────────────────────────────────────────
# 프로덕션에서는 반드시 false로 설정
ALLOW_UNAUTHENTICATED=true
